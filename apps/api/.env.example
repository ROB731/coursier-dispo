# Base de données
DATABASE_URL="postgresql://user:password@localhost:5432/dispo_coursier?schema=public"

# Serveur
PORT=4000
NODE_ENV=development

# Sécurité
JWT_SECRET="change-me-in-production-minimum-32-caracteres"
JWT_EXPIRATION="12h"

# CORS — origine du frontend Next.js
FRONTEND_ORIGIN="http://localhost:3000"

# Compte Super Administrateur créé au premier seed (jamais de mot de passe en dur dans le code)
SEED_SUPER_ADMIN_IDENTIFIANT="admin"
SEED_SUPER_ADMIN_MOT_DE_PASSE="ChangeMoiAuPremierLogin!"

# Notifications Web Push (VAPID) — générer avec `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_CONTACT_EMAIL="mailto:contact@ivoirrapid.example"
