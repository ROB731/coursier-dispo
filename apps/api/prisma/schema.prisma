// DISPO-COURSIER — Schéma de données
// Voir docs/04-architecture.md pour le modèle conceptuel et docs/05-database.md
// pour la stratégie d'index, de seed et de migration.
//
// Modèle multi-entreprises (docs/06-multi-entreprise.md) : Entreprise est la
// frontière d'isolation des données (tenant). Site, ProfilHoraire et
// ParametresApplication sont rattachés à une Entreprise. Un Utilisateur
// SUPER_ADMIN n'est rattaché à aucune entreprise (accès plateforme). Un
// DIRECTEUR est rattaché à une ou plusieurs entreprises (DirecteurEntreprise).
// Un GERANTE est rattaché soit directement à une entreprise (entrepriseId),
// soit à un directeur (directeurId) dont il hérite alors le périmètre.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Enums ----------

enum RoleUtilisateur {
  SUPER_ADMIN
  DIRECTEUR
  GERANTE
}

enum TypeContrat {
  CDI
  CDD
  STAGIAIRE
  PRESTATAIRE
}

enum TypeEvenement {
  ENTREE
  SORTIE
  ANNULATION
  CLOTURE_AUTO
}

enum SourceEvenement {
  BORNE
  COMPTE
  SYSTEME
}

enum TypeNotification {
  COURSIER_ARRIVE
  AUCUN_DISPONIBLE
}

// ---------- Entreprises (tenants) ----------

model Entreprise {
  id        String   @id @default(uuid())
  nom       String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites                Site[]
  profilsHoraires      ProfilHoraire[]
  parametres           ParametresApplication?
  utilisateursDirects  Utilisateur[]         @relation("UtilisateurEntreprise")
  directeurEntreprises DirecteurEntreprise[]
  journalActivite      JournalActivite[]

  @@index([actif])
}

// Relation many-to-many : un Directeur peut être rattaché à plusieurs
// entreprises ; une entreprise peut avoir plusieurs directeurs.
model DirecteurEntreprise {
  id           String      @id @default(uuid())
  directeur    Utilisateur @relation(fields: [directeurId], references: [id], onDelete: Cascade)
  directeurId  String
  entreprise   Entreprise  @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  entrepriseId String
  createdAt    DateTime    @default(now())

  @@unique([directeurId, entrepriseId])
  @@index([entrepriseId])
}

// ---------- Comptes ----------

model Utilisateur {
  id                  String            @id @default(uuid())
  identifiant         String            @unique
  motDePasseHash      String
  role                RoleUtilisateur
  nomComplet          String
  telephone           String?
  email               String?
  siteParDefaut       Site?             @relation("UtilisateurSiteParDefaut", fields: [siteParDefautId], references: [id])
  siteParDefautId     String?

  // GERANTE uniquement : rattachement direct à une entreprise. Alternative à directeurId.
  entreprise          Entreprise?       @relation("UtilisateurEntreprise", fields: [entrepriseId], references: [id])
  entrepriseId        String?

  // GERANTE uniquement : rattachement à un directeur, dont le périmètre d'entreprises est hérité.
  directeur           Utilisateur?      @relation("GeranteDirecteur", fields: [directeurId], references: [id])
  directeurId         String?
  gerantes            Utilisateur[]     @relation("GeranteDirecteur")

  // DIRECTEUR uniquement : entreprises supervisées.
  directeurEntreprises DirecteurEntreprise[]

  actif               Boolean           @default(true)
  derniereConnexionAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  evenementsAnnulesPar Evenement[]      @relation("EvenementCreePar")
  pushSubscriptions    PushSubscription[]
  notifications        Notification[]
  journalActivite      JournalActivite[]

  @@index([role])
  @@index([entrepriseId])
  @@index([directeurId])
}

// ---------- Journal d'activité (audit des actions de gestion) ----------

model JournalActivite {
  id             String       @id @default(uuid())
  utilisateur    Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)
  utilisateurId  String?
  nomUtilisateur String
  action         String
  cible          String?
  entreprise     Entreprise?  @relation(fields: [entrepriseId], references: [id], onDelete: SetNull)
  entrepriseId   String?
  createdAt      DateTime     @default(now())

  @@index([utilisateurId, createdAt])
  @@index([entrepriseId, createdAt])
  @@index([createdAt])
}

// ---------- Sites & Bornes ----------

model Site {
  id               String     @id @default(uuid())
  entreprise       Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Restrict)
  entrepriseId     String
  nom              String
  adresse          String?
  ville            String?
  estSitePrincipal Boolean    @default(false)
  actif            Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  coursierSites         CoursierSite[]
  terminaux             Terminal[]
  evenements             Evenement[]
  utilisateursParDefaut  Utilisateur[]  @relation("UtilisateurSiteParDefaut")

  @@index([actif])
  @@index([entrepriseId])
}

model Terminal {
  id                 String    @id @default(uuid())
  nom                String
  site               Site      @relation(fields: [siteId], references: [id], onDelete: Restrict)
  siteId             String
  derniereActiviteAt DateTime?
  actif              Boolean   @default(true)
  createdAt          DateTime  @default(now())

  evenements         Evenement[]

  @@index([siteId])
}

// ---------- Coursiers ----------

model Coursier {
  id                      String        @id @default(uuid())
  code                    String        @unique
  photoUrl                String
  prenom                  String
  nom                     String
  telephone               String?
  email                   String?
  dateNaissance           DateTime?     @db.Date
  adresse                 String?
  typeContrat             TypeContrat?
  dateEmbauche            DateTime?     @db.Date
  contactUrgenceNom       String?
  contactUrgenceTelephone String?
  statutActif             Boolean       @default(true)
  profilHoraire           ProfilHoraire @relation(fields: [profilHoraireId], references: [id], onDelete: Restrict)
  profilHoraireId         String
  multiSiteActive         Boolean       @default(false)
  notes                   String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  coursierSites           CoursierSite[]
  evenements              Evenement[]
  notifications           Notification[]

  @@index([statutActif])
  @@index([profilHoraireId])
}

model CoursierSite {
  id               String   @id @default(uuid())
  coursier         Coursier @relation(fields: [coursierId], references: [id], onDelete: Cascade)
  coursierId       String
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  siteId           String
  estSitePrincipal Boolean  @default(true)
  actif            Boolean  @default(true)

  // Un coursier n'a qu'une ligne par site ; le nombre de sites simultanés
  // actifs est contraint au niveau applicatif par Coursier.multiSiteActive.
  @@unique([coursierId, siteId])
  @@index([siteId])
}

// horaires : { "LUN": {"debut":"08:00","fin":"17:30"}, "SAM": {"debut":"08:00","fin":"13:00"}, ... }
// Une clé absente = jour non travaillé. Permet des horaires différents le
// week-end (samedi/dimanche) du reste de la semaine.
// horaires : { "LUN": {"debut":"08:00","fin":"17:30"}, "SAM": {"debut":"08:00","fin":"13:00"}, ... }
// Une clé absente = jour non travaillé. Permet des horaires différents le
// week-end (samedi/dimanche) du reste de la semaine.
model ProfilHoraire {
  id           String     @id @default(uuid())
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Restrict)
  entrepriseId String
  nom          String
  horaires     Json
  estParDefaut Boolean    @default(false)
  actif        Boolean    @default(true)

  coursiers    Coursier[]

  @@index([entrepriseId])
}

// ---------- Historique (append-only) ----------

model Evenement {
  id                   String          @id @default(uuid())
  coursier             Coursier        @relation(fields: [coursierId], references: [id], onDelete: Restrict)
  coursierId           String
  site                 Site            @relation(fields: [siteId], references: [id], onDelete: Restrict)
  siteId               String
  type                 TypeEvenement
  // Renseigné uniquement si type = ANNULATION : pointe vers l'événement annulé.
  evenementAnnule       Evenement?      @relation("Annulation", fields: [evenementAnnuleId], references: [id])
  evenementAnnuleId     String?         @unique
  annulePar             Evenement?      @relation("Annulation")
  source               SourceEvenement
  terminal             Terminal?       @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  terminalId           String?
  creeParUtilisateur   Utilisateur?    @relation("EvenementCreePar", fields: [creeParUtilisateurId], references: [id], onDelete: SetNull)
  creeParUtilisateurId String?
  horodatage           DateTime
  createdAt            DateTime        @default(now())

  @@index([coursierId, horodatage])
  @@index([siteId, horodatage])
  @@index([type])
}

// ---------- Notifications ----------

model PushSubscription {
  id            String      @id @default(uuid())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  utilisateurId String
  endpoint      String      @unique
  p256dh        String
  auth          String
  createdAt     DateTime    @default(now())
}

model Notification {
  id            String            @id @default(uuid())
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  utilisateurId String
  type          TypeNotification
  coursier      Coursier?         @relation(fields: [coursierId], references: [id], onDelete: SetNull)
  coursierId    String?
  message       String
  lu            Boolean           @default(false)
  envoyeAt      DateTime          @default(now())

  @@index([utilisateurId, lu])
}

// ---------- Paramètres (un jeu par entreprise) ----------

model ParametresApplication {
  id                            String      @id @default(uuid())
  entreprise                    Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  entrepriseId                  String     @unique
  modeMultiSite                 Boolean    @default(false)
  fenetreAnnulationBorneMinutes Int        @default(2)
  intervallePollingSecondes     Int        @default(7)
  clotureAutoActive             Boolean    @default(true)
}
